;var(8)  --> (decide que movimiento hara la IA desde la pocicion de stand)
;var(9)  --> acriva triple pindanger
;var(10) --> determina si ya se hiso algun fatal move
;var(12) --> evalua si se puede hacer un combo de stand despues de impacto aereo.
;var(13) --> Stage interact
;var(14) --> Stage interact
;Var(32) --> gethitcount
;Var(35) --> combocount
;var(59) --> para evaluar la IA
;var(7)  --> para determinar cundo hacer un breaker (IA)
;var(6)  --> deciciones de combos por la IA

[StateDef -3]

;=============
;Damage Correct
;=============
[State Mul Set]
type = AttackMulSet
trigger1 = 1
value = 1/(1+Var(35)/7.)

;===========
;Combo Count
;===========
[State Inc Combo Count]
type = VarAdd
trigger1 = HitCount-Var(34) > 0
ignorehitpause = 1
var(35) = 1

[State PrevHitCount]
type = VarSet
trigger1 = 1
ignorehitpause = 1
var(34) = HitCount


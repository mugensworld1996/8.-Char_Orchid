[StateDef -4]

;===============
;Stop Dizzy Snd
;===============
[State Dizzy]
type = StopSnd
trigger1 = StateNo != [5300,5302]
trigger1 = StateNo != 800
trigger1 = Var(3)
ignorehitpause = 1
channel = 2

[State VarSet]
type = VarSet
trigger1 = StateNo != [5300,5302]
trigger1 = StateNo != 800
ignorehitpause = 1
var(3) = 0






triggerall = Time = 1
trigger1 = StateNo = 5000
trigger2 = StateNo = 5010
trigger3 = StateNo = 5020
trigger4 = StateNo = 5070
trigger5 = StateNo = 5080
ignorehitpasue = 1
var(32) = 1

[State Get Hit Count Reset]
type = VarSet
trigger1 = MoveType != H
var(32) = 0

[State Dizzy value Minus]
type = VarAdd
trigger1 = 1
var(1) = -IfElse(Var(1)>=1,1,Var(1))


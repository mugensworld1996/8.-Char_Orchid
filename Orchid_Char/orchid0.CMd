;; uses var(13) to count the fight time, this is needed since GameTime does
; not reset on each fight of arcade mode.
[State -1] 
type = VarAdd
trigger1 = 1
v = 13
value = 1


; identifies orchid stage, that has in StageID number of 55501
; if you want your character to react to other stages, add more triggers like this one, but change the ID number
; this trigger sets var(14) to stage ID number
[State -1] 
type = VarSet
triggerall = Var(13) = [1,3]
triggerall = var(14) = 0
trigger1 = ScreenPos Y = 55501 ; Vega Stage
;trigger2 = ScreenPos Y =   ; add your stage here
v = 14
value = floor(ScreenPos Y)



;----------------------
; CUSTOM STATES DO P2 :
;----------------------

;Dizzy com tempo . Antes do fatality.

[Statedef 003]
type    = S
movetype= H
physics = N
juggle  = 1
ctrl = 0
velset = 0,0

[State 003, 1]
type = LifeSet
trigger1 = 1
value = 1

[State 003, 1]
type = varset
trigger1 = 1
var(59)=0

[State 003, 1]
type = TargetLifeAdd
trigger1 = P2life <= 1
value = 1

[State 003, 1]
type = LifeSet
trigger1 = P2StateNo != [8000,8999]
trigger1 = Time = 0
value = 0

[State 003, 1]
type = SelfState
trigger1 = P2StateNo != [8000,8999]
trigger1 = Time = 0
value = 5050
ctrl = 0

[State 003, 1]
type = ChangeState
trigger1 = P2StateNo = [8000,8999]
value = 004
ctrl = 0

[State 003, 2]
type = ChangeAnim 
trigger1 = AnimExist(5300)
trigger1 = Anim != 5300
value = 5300

[state 003, 2]
type = AssertSpecial
trigger1 = p2stateno = 21000
trigger2 = p2stateno = 21005
flag = noshadow


; Dizzy sem tempo

[Statedef 004]
type    = S
movetype= H
physics = N
juggle  = 1
velset = 0,0
ctrl = 0

[State 004, 1]
type = varset
trigger1 = 1
var(59)=0

[State 004, 1]
type = ChangeState
trigger1 = P2StateNo = 8551
value = 50005 ;-> Custom State para onde P2 vai após sua personagem iniciar os golpes.
ctrl = 0 

[State 004, 2]
type = ChangeAnim 
trigger1 = AnimExist(5300)
trigger1 = Anim != 5300
value = 5300
;===========================================================


; Stance standing
[Statedef 0]
type = S
physics = S

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0 && Anim != 5 && Anim != 6000
trigger2 = Anim = 5 && AnimTime = 0
value = IfElse((Var(1) > 0),0,0)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3]
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

; Jump Start
[Statedef 40]
type = S
physics = S
anim = 40
ctrl = 0

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = Time = 0
var(5) = 0

[State 40, 3]
type = VarSet
trigger1 = command = "longjump"
trigger2 = prevstateno = 100 && command = "holdfwd"
trigger3 = prevstateno = 91002
var(5) = 1

[State 40, 4]
type = VarSet
trigger1 = command = "holdfwd"
trigger2 = prevstateno = 91002
sysvar(1) = 1

[State 40, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 6]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 6.1]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = var(5)
y = (const(velocity.jump.y))-7

[State 40, 7]
type = PlaySnd
trigger1 = AnimTime = 0 && (Var(5) = 0 || (Var(5) && Sysvar(1) = 0))
value = 40,0

[State 40, 8]
type = PlaySnd
trigger1 = Var(5) && Sysvar(1) != 0 && AnimTime = 0 
value = 40,1

[State 40, 10]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = VelSet
trigger1 = Time = 0 && Var(5)
x = IfElse(vel x = 0,0,IfElse(vel x < 0,-4.8,4.8))

[State 50, 3]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 41, 43))

[State 50, 4]
type = AfterImage
trigger1 = Time = 0 && Var(5) && Vel X != 0
time = 10
trans = add1
timegap = 1
framegap = 2
length = 8
palbright = 0,0,0
palcontrast = 128,128,128
palmul = 1,1,1

; Time over (lose)
[Statedef 170]
type = S
anim = 170

[State 170, 1]
type = AssertSpecial
trigger1 = Time = [0,40]
flag = RoundNotOver

; Time over (draw)
[Statedef 175]
type = S
anim = 175

[State 175, 1]
type = AssertSpecial
trigger1 = Time = [0,65]
flag = RoundNotOver

